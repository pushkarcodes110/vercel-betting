{
  "version": 2,
  "builds": [
    {
      "src": "api/[[...route]].ts",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/[[...route]].ts": {
      "runtime": "@vercel/node@3.2.24"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[[...route]].ts"
    }
  ]
}
